{
  "name": "@jup-ag/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "jup": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "docs",
    "llms.txt",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm --minify",
    "build:binary": "bash scripts/build.sh",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx oxlint src",
    "test": "bun test",
    "ci": "bun run lint && bun run typecheck && bun run test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.53.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@solana-program/token": "^0.12.0",
    "@solana/kit": "^6.2.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ky": "^1.14.3"
  }
}
